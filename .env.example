MODEL=gemini-2.0-flash
GOOGLE_API_KEY=

# Supabase PostgreSQL. Copie a connection string do Supabase e use sslmode=require.
# Exemplo: postgresql://postgres:SENHA@db.PROJECT_REF.supabase.co:5432/postgres?sslmode=require
SUPABASE_DATABASE_URL=

# Evolution API.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=

# Opcional. Se preencher, configure a Evolution para chamar o webhook com ?token=VALOR
# ou com o header x-webhook-token.
EVOLUTION_WEBHOOK_TOKEN=

# Opcional.
AGENT_MAX_HISTORY_MESSAGES=12
REQUEST_TIMEOUT_SECONDS=20
